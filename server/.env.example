# Server environment variables
# Copy this file to .env and fill in your values

PORT=5000

# Gemini API Key (from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase credentials (from supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here
SUPABASE_SERVICE_KEY=sb_secret_your_service_key_here

# JWT Secret (any random string)
JWT_SECRET=your_random_secret_here

# Discord Webhook URL for real-time notifications/feedback
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here


